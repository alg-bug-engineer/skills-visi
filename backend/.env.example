DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT_S=60

# PostgreSQL
PGHOST=121.40.233.80
PGPORT=15432
PGUSER=ycx
PGPASSWORD=your_password_here
