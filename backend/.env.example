# LLM (阿里百炼 DashScope OpenAI 兼容)
DASHSCOPE_API_KEY=your_api_key_here
# 业务空间 ID；Qwen-TTS Realtime 通过请求头 X-DashScope-WorkSpace 传递
DASHSCOPE_WORKSPACE_ID=ws-rse51vi7zlnjhsaf
QWEN_MODEL=qwen3.6-flash-2026-04-16
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT_S=60
# 可选：Clash TUN 等导致直连 dashscope 失败时，仅 LLM 走本地 HTTP 代理（勿提交真实值）
# LLM_HTTP_PROXY=http://127.0.0.1:7897

# PostgreSQL
PGHOST=121.40.233.80
PGPORT=15432
PGUSER=ycx
PGPASSWORD=your_password_here
PGDATABASE=ycx
PGSCHEMA=road6
PG_FLOW_SCHEMA=xianchang
PG_VERSION_ID=20260501

# Application
LOG_LEVEL=INFO
LOG_FILE=data/logs/app.log
SKILL_DIR_PATH=data/skills
MOCK_LLM=0
MOCK_DB=0
# 演示模式：锚定 config/demo_intersections.yaml 中的 reference_date
DEMO_MODE=0
HOST=0.0.0.0
PORT=8011
# 生产前端端口（prod-start.sh 读取，默认 5568，禁止 80）
# HTTP_PORT=5568
CORS_ORIGINS=*
# PUBLIC_URL=http://your-ecs-public-ip

# Qwen-TTS Realtime（百炼 DashScope WebSocket）
QWEN_TTS_MODEL=qwen3-tts-flash-realtime
QWEN_TTS_VOICE=Cherry
QWEN_TTS_MODE=commit
QWEN_TTS_SAMPLE_RATE=24000
TTS_ENABLED=1
