-- DWD 数据日历范围
SELECT inter_id, MIN(stat_time::date) d_from, MAX(stat_time::date) d_to, COUNT(DISTINCT stat_time::date) days
FROM dwd_tfc_inter_dir_perf_5min
WHERE inter_id IN ('011wwe295cm00001','011wwe28ctu00001') AND is_deleted=0
GROUP BY inter_id;

-- 晚高峰(16-18) 常发性：近7日超标天数
WITH daily AS (
  SELECT inter_id, stat_time::date AS d,
         AVG(stop_time) avg_stop, MAX(queue_len_max) max_q
  FROM dwd_tfc_inter_dir_perf_5min
  WHERE inter_id IN ('011wwe295cm00001','011wwe28ctu00001') AND is_deleted=0
    AND stat_time::time >= '16:00' AND stat_time::time < '18:00'
  GROUP BY 1,2
)
SELECT d.inter_id, i.inter_name,
       COUNT(*) total_days,
       COUNT(*) FILTER (WHERE avg_stop >= 60 OR max_q >= 100) congested_days,
       ROUND(AVG(avg_stop)::numeric,1) avg_stop_s,
       MAX(max_q) peak_queue_m
FROM daily d
JOIN dim_inter_info i ON i.inter_id=d.inter_id AND i.version_id='20260501'
GROUP BY d.inter_id, i.inter_name;

-- 晚高峰 DWS 饱和度/失衡
SELECT e.inter_id, i.inter_name,
       ROUND(AVG(saturation_max)::numeric,3) avg_sat,
       ROUND(AVG(unbalance_index)::numeric,3) avg_imbalance,
       COUNT(*) cnt
FROM dws_inter_evaluation_5min_mm e
JOIN dim_inter_info i ON i.inter_id=e.inter_id AND i.version_id='20260501'
WHERE e.inter_id IN ('011wwe295cm00001','011wwe28ctu00001')
  AND e.is_deleted=0 AND e.step_index BETWEEN 192 AND 215
GROUP BY e.inter_id, i.inter_name;
