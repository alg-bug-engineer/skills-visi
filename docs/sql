-- 新泺大街 分方向晚高峰
SELECT f_dir_8_label,
       ROUND(AVG(queue_len_avg)::numeric,1) avg_q,
       ROUND(MAX(queue_len_max)::numeric,1) max_q,
       ROUND(AVG(stop_time)::numeric,1) avg_stop
FROM dws_inter_dir_turn_perf_5min_mm
WHERE inter_id='011wwe295cm00001' AND is_deleted=0 AND turn_dir_no=0
  AND step_index BETWEEN 192 AND 215
GROUP BY f_dir_8_label ORDER BY max_q DESC;



