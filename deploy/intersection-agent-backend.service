[Unit]
Description=Intersection Agent Backend (FastAPI)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/intersection-agent/backend
EnvironmentFile=/var/www/intersection-agent/backend/.env
ExecStart=/var/www/intersection-agent/backend/.venv/bin/uvicorn intersection_agent.main:app --host 0.0.0.0 --port 8011
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
